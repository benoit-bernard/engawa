<header class="site-header" role="banner">
    <nav class="nav-container" aria-label="Navigation principale">

        <a class="nav-brand" href="/" aria-label="Engawa — Accueil">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 60" fill="none" class="nav-logo" aria-hidden="true">
                <circle cx="38" cy="30" r="25" fill="#C8DCE8" opacity="0.75" />
                <circle cx="38" cy="30" r="17" fill="#9BBDD2" opacity="0.9" />
                <circle cx="38" cy="30" r="10" fill="#7BAFC8" />
                <circle cx="72" cy="30" r="25" fill="#E8D5BB" opacity="0.75" />
                <circle cx="72" cy="30" r="17" fill="#D4BC96" opacity="0.9" />
                <circle cx="72" cy="30" r="10" fill="#C4A882" />
            </svg>
            <span class="nav-brand-text">ENGAWA</span>
        </a>

        <button class="nav-hamburger" aria-label="Menu" aria-expanded="@_menuOpen" @onclick="ToggleMenu">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>

        <ul class="nav-links @(_menuOpen ? "nav-links--open" : "")" role="list">
            <li>
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">
                    Accueil
                </NavLink>
            </li>
            <li>
                <NavLink class="nav-link" href="/philosophy" @onclick="CloseMenu">
                    Philosophie
                </NavLink>
            </li>
            <li>
                <NavLink class="nav-link" href="/contact" @onclick="CloseMenu">
                    Contact
                </NavLink>
            </li>
            <li>
                <NavLink class="nav-link" href="/legal" @onclick="CloseMenu">
                    CGU
                </NavLink>
            </li>
        </ul>

    </nav>
</header>

@code {
    private bool _menuOpen;

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu()  => _menuOpen = false;
}
