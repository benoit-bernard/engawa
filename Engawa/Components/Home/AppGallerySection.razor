<section class="app-gallery" aria-labelledby="gallery-title">
    <div class="container">

        <SectionTitle Title="App Gallery"
                      Eyebrow="Applications éthiques"
                      Subtitle="Des outils numériques conçus selon nos principes. Bientôt disponibles." />

        <div class="gallery-grid">
            @foreach (var app in _placeholderApps)
            {
                <div class="gallery-card" data-reveal data-reveal-delay="@app.Delay">
                    <div class="gallery-card__badge">Bientôt</div>
                    <div class="gallery-card__icon" aria-hidden="true">@((MarkupString)app.Icon)</div>
                    <h3 class="gallery-card__name">@app.Name</h3>
                    <p class="gallery-card__desc">@app.Description</p>
                    <div class="gallery-card__tags">
                        @foreach (var tag in app.Tags)
                        {
                            <span class="tag">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="gallery-cta" data-reveal>
            <p>Vous avez un projet éthique à réaliser ?</p>
            <a href="/contact" class="gallery-cta-link">Travaillons ensemble →</a>
        </div>

    </div>
</section>

@code {
    private record AppPlaceholder(string Icon, string Name, string Description, string[] Tags, string Delay);

    private readonly AppPlaceholder[] _placeholderApps =
    [
        new("&#128274;", "Liste de cadeaux", "Sans aucun doute la meilleure application liste de cadeaux éthique.", ["Ethique", "Fonctionnalités", "Pour tous"], "1"),
        new("&#128203;", "A venir", "Une application pour les propriétaires.", ["Formulaires", "Souverain", "Propriétaires"], "2"),
        new("&#127968;", "A venir", "Consommer éthique.", ["Pour tous", "Ethique", "Little steps"], "3"),
    ];
}
